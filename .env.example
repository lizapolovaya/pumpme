# Storage driver: "sqlite" (default) or "supabase"
PUMPME_STORAGE_DRIVER=sqlite

# SQLite (used when PUMPME_STORAGE_DRIVER=sqlite)
PUMPME_SQLITE_PATH=

# Supabase (used when PUMPME_STORAGE_DRIVER=supabase)
# Server-side URL + key used by the API routes / server components.
# Use the service role key for development if you have not configured RLS yet.
PUMPME_SUPABASE_URL=
PUMPME_SUPABASE_ANON_KEY=
PUMPME_SUPABASE_SERVICE_ROLE_KEY=

# Optional: client-side Supabase (only needed if we start using Supabase in the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

